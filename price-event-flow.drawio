<mxfile host="app.diagrams.net" modified="2026-03-18T00:00:00.000Z" agent="Claude" version="21.0.0" type="device">
  <diagram name="Price Event Flow" id="price-event-flow">
    <mxGraphModel dx="1200" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="title" value="Price Event Flow — Kafka Consumer Chain" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="35" as="geometry"/>
        </mxCell>

        <!-- ───────────────────────────────────────────
             ROW 1 — External + Producer
        ─────────────────────────────────────────── -->

        <mxCell id="yahoo" value="&lt;b&gt;Yahoo Finance v8&lt;/b&gt;&lt;br&gt;Real baseline prices&lt;br&gt;(startup fetch, no key)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E64A19;fontColor=#ffffff;strokeColor=#BF360C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="65" width="175" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="price_producer" value="&lt;b&gt;PriceProducer&lt;/b&gt;&lt;br&gt;price-service :8083&lt;br&gt;±1.5% random walk / 15s&lt;br&gt;@PostConstruct init" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565C0;fontColor=#ffffff;strokeColor=#0D47A1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="60" width="185" height="80" as="geometry"/>
        </mxCell>

        <!-- ───────────────────────────────────────────
             ROW 2 — prices.live.topic
        ─────────────────────────────────────────── -->

        <mxCell id="topic_live" value="&lt;b&gt;prices.live.topic&lt;/b&gt;&lt;br&gt;PriceEvent&lt;br&gt;(price, open, high, low, prevClose)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF59D;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="210" width="230" height="65" as="geometry"/>
        </mxCell>

        <!-- ───────────────────────────────────────────
             ROW 3 — Two consumers of prices.live.topic
        ─────────────────────────────────────────── -->

        <mxCell id="price_redis_consumer" value="&lt;b&gt;PriceRedisConsumer&lt;/b&gt;&lt;br&gt;price-service&lt;br&gt;group: price-redis-group&lt;br&gt;Writes price hash to Redis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#283593;fontColor=#ffffff;strokeColor=#1A237E;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="360" width="210" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="price_consumer" value="&lt;b&gt;PriceConsumer&lt;/b&gt;&lt;br&gt;price-service&lt;br&gt;group: price-consumer-group&lt;br&gt;Republishes as PriceUpdatedEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#283593;fontColor=#ffffff;strokeColor=#1A237E;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="360" width="215" height="80" as="geometry"/>
        </mxCell>

        <!-- ───────────────────────────────────────────
             ROW 3 — Redis (right of PriceRedisConsumer)
        ─────────────────────────────────────────── -->

        <mxCell id="redis" value="&lt;b&gt;Redis&lt;/b&gt;&lt;br&gt;price:{symbol} hash&lt;br&gt;(price, open, high, low,&lt;br&gt;prevClose, timestamp)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=16;fillColor=#6A1B9A;fontColor=#ffffff;strokeColor=#4A148C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="520" width="190" height="100" as="geometry"/>
        </mxCell>

        <!-- ───────────────────────────────────────────
             ROW 4 — prices.updated.topic
        ─────────────────────────────────────────── -->

        <mxCell id="topic_updated" value="&lt;b&gt;prices.updated.topic&lt;/b&gt;&lt;br&gt;PriceUpdatedEvent&lt;br&gt;(symbol, price)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF59D;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="520" width="215" height="65" as="geometry"/>
        </mxCell>

        <!-- ───────────────────────────────────────────
             ROW 5 — PriceUpdatedConsumer in portfolio-service
        ─────────────────────────────────────────── -->

        <mxCell id="price_updated_consumer" value="&lt;b&gt;PriceUpdatedConsumer&lt;/b&gt;&lt;br&gt;portfolio-service :8087&lt;br&gt;group: portfolio-cache-group&lt;br&gt;Looks up holders via Redis&lt;br&gt;Invalidates portfolio cache&lt;br&gt;Calls PortfolioPushService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565C0;fontColor=#ffffff;strokeColor=#0D47A1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="490" width="220" height="110" as="geometry"/>
        </mxCell>

        <!-- ───────────────────────────────────────────
             ROW 5 — Redis read (symbol holders)
        ─────────────────────────────────────────── -->

        <mxCell id="redis2" value="&lt;b&gt;Redis&lt;/b&gt;&lt;br&gt;manager:accounts:{id}&lt;br&gt;account:manager:{id}&lt;br&gt;portfolio:{id} (30s TTL)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=16;fillColor=#6A1B9A;fontColor=#ffffff;strokeColor=#4A148C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="990" y="490" width="190" height="110" as="geometry"/>
        </mxCell>

        <!-- ───────────────────────────────────────────
             ROW 6 — Browser Dashboard (WebSocket target)
        ─────────────────────────────────────────── -->

        <mxCell id="browser" value="&lt;b&gt;Browser Dashboard&lt;/b&gt;&lt;br&gt;localhost:8087/&lt;br&gt;/topic/portfolio/{accountId}&lt;br&gt;Sparkline + PnL update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BF360C;fontColor=#ffffff;strokeColor=#7F0000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="640" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             EDGES
        ═══════════════════════════════════════════════ -->

        <!-- Yahoo Finance → PriceProducer (startup fetch) -->
        <mxCell id="e_yahoo_producer" value="@PostConstruct fetch&lt;br&gt;(1.2s delay / symbol)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#BF360C;strokeWidth=2;fontColor=#BF360C;fontSize=9;dashed=1;" edge="1" source="yahoo" target="price_producer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PriceProducer → prices.live.topic -->
        <mxCell id="e_producer_live" value="publish PriceEvent&lt;br&gt;@Scheduled 15s" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;fontColor=#E65100;fontSize=9;" edge="1" source="price_producer" target="topic_live" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- prices.live.topic → PriceRedisConsumer -->
        <mxCell id="e_live_redis_consumer" value="price-redis-group" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;fontColor=#E65100;fontSize=9;dashed=1;" edge="1" source="topic_live" target="price_redis_consumer" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="455" y="300"/>
              <mxPoint x="205" y="300"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- prices.live.topic → PriceConsumer -->
        <mxCell id="e_live_consumer" value="price-consumer-group" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;fontColor=#E65100;fontSize=9;dashed=1;" edge="1" source="topic_live" target="price_consumer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PriceRedisConsumer → Redis -->
        <mxCell id="e_redis_write" value="HSET price:{symbol}" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6A1B9A;strokeWidth=2;fontColor=#6A1B9A;fontSize=9;" edge="1" source="price_redis_consumer" target="redis" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PriceConsumer → prices.updated.topic -->
        <mxCell id="e_consumer_updated" value="publish PriceUpdatedEvent" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;fontColor=#E65100;fontSize=9;" edge="1" source="price_consumer" target="topic_updated" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- prices.updated.topic → PriceUpdatedConsumer (portfolio-service) -->
        <mxCell id="e_updated_portfolio" value="portfolio-cache-group" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;fontColor=#E65100;fontSize=9;dashed=1;" edge="1" source="topic_updated" target="price_updated_consumer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PriceUpdatedConsumer → Redis (read holders + invalidate) -->
        <mxCell id="e_portfolio_redis" value="getSymbolHolders()&lt;br&gt;invalidatePortfolio()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6A1B9A;strokeWidth=2;fontColor=#6A1B9A;fontSize=9;" edge="1" source="price_updated_consumer" target="redis2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PriceUpdatedConsumer → Browser (WebSocket push) -->
        <mxCell id="e_portfolio_ws" value="STOMP push&lt;br&gt;/topic/portfolio/{accountId}" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3949AB;strokeWidth=2;fontColor=#3949AB;fontSize=9;" edge="1" source="price_updated_consumer" target="browser" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             CONSUMER GROUP LABELS (annotation boxes)
        ═══════════════════════════════════════════════ -->

        <mxCell id="note_two_groups" value="&lt;b&gt;Two independent consumer groups&lt;/b&gt; on prices.live.topic:&lt;br&gt;• &lt;b&gt;price-redis-group&lt;/b&gt; → writes Redis only (failure retried without affecting Kafka publish)&lt;br&gt;• &lt;b&gt;price-consumer-group&lt;/b&gt; → republishes to prices.updated.topic only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;fontStyle=2;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="670" y="200" width="680" height="65" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             LEGEND
        ═══════════════════════════════════════════════ -->

        <mxCell id="legend_bg" value="&lt;b&gt;Legend&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#9E9E9E;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="490" width="175" height="135" as="geometry"/>
        </mxCell>

        <mxCell id="leg_kpub" value="" style="edgeStyle=none;strokeColor=#E65100;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1220" y="530" as="sourcePoint"/>
            <mxPoint x="1265" y="530" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_kpub_txt" value="Kafka publish" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="1272" y="521" width="110" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="leg_kcon" value="" style="edgeStyle=none;strokeColor=#E65100;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1220" y="555" as="sourcePoint"/>
            <mxPoint x="1265" y="555" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_kcon_txt" value="Kafka consume" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="1272" y="546" width="110" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="leg_redis" value="" style="edgeStyle=none;strokeColor=#6A1B9A;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1220" y="580" as="sourcePoint"/>
            <mxPoint x="1265" y="580" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_redis_txt" value="Redis read/write" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="1272" y="571" width="110" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="leg_ws" value="" style="edgeStyle=none;strokeColor=#3949AB;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1220" y="605" as="sourcePoint"/>
            <mxPoint x="1265" y="605" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg_ws_txt" value="WebSocket (STOMP)" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="1272" y="596" width="110" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
